{
  "name": "Kocom Wallpad with RS485",
  "version": "2026.05.30",
  "slug": "kocom_py",
  "description": "Kocom Wallpad for Home Assistant",
  "arch": [
    "armhf",
    "armv7",
    "aarch64",
    "amd64",
    "i386"
  ],
  "url": "https://github.com/iuscaler/kocom_wallpad_app_for_homeassistant",
  "startup": "application",
  "boot": "auto",
  "uart": true,
  "map": [
    "share:rw"
  ],
  "options": {
    "rs485_type": "serial",
    "serial_port": "/dev/serial/by-id/usb-1a86_USB_Serial-if00-port0",
    "socket_server": "",
    "socket_port": 8899,
    "mqtt_server": "172.30.32.1",
    "mqtt_port": 1883,
    "mqtt_allow_anonymous": false,
    "mqtt_username": "",
    "mqtt_password": "",
    "devices": [
      "light_livingroom",
      "fan_livingroom",
      "thermo_livingroom",
      "thermo_room1",
      "thermo_room2",
      "thermo_room3",
      "thermo_kitchen",
      "elevator"
    ],
    "elevator_type": "rs485",
    "rs485_floor": 7,
    "init_temp": 23,
    "init_fan_mode": "Medium",
    "light_count": 2,
    "log_recv_hex": false,
    "log_mqtt_publish": false
  },
  "schema": {
    "rs485_type": "list(serial|socket)",
    "serial_port": "str?",
    "socket_server": "str?",
    "socket_port": "int?",
    "mqtt_server": "str",
    "mqtt_port": "int",
    "mqtt_allow_anonymous": "bool",
    "mqtt_username": "str?",
    "mqtt_password": "password?",
    "devices": ["str"],
    "elevator_type": "list(rs485|tcpip)",
    "rs485_floor": "int",
    "init_temp": "int",
    "init_fan_mode": "list(Low|Medium|High)",
    "light_count": "int",
    "log_recv_hex": "bool",
    "log_mqtt_publish": "bool"
  }
}
